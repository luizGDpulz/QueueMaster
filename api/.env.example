# ============================================================================
# QueueMaster API - Environment Configuration
# ============================================================================
# Copy this file to .env and configure the values for your environment.
# NEVER commit the .env file to version control!

# ----------------------------------------------------------------------------
# DATABASE (Required)
# ----------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=queue_master

# ----------------------------------------------------------------------------
# JWT AUTHENTICATION (Required)
# ----------------------------------------------------------------------------
# Generate RSA keys with:
#   openssl genrsa -out keys/private.key 2048
#   openssl rsa -in keys/private.key -pubout -out keys/public.key
JWT_PRIVATE_KEY_PATH=keys/private.key
JWT_PUBLIC_KEY_PATH=keys/public.key
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000

# ----------------------------------------------------------------------------
# GOOGLE OAUTH (Required)
# ----------------------------------------------------------------------------
# Get from: Google Cloud Console -> APIs & Services -> Credentials
# Create: OAuth 2.0 Client ID (Web application)
# Add Authorized JavaScript origins: http://localhost:9000
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# IMPORTANT: Set your email here BEFORE first login to become admin
# The first user to login with this email will have 'admin' role
SUPER_ADMIN_EMAIL=your.email@gmail.com

# Optional access control for test/staging environments
# Comma-separated exact emails and/or domains allowed/blocked from login.
# Leave empty to disable the corresponding rule.
# Precedence:
# 1. AUTH_BLOCKED_EMAILS always denies
# 2. AUTH_ALLOWED_EMAILS explicitly allows and overrides blocked domains
# 3. AUTH_BLOCKED_EMAIL_DOMAINS denies when the email was not explicitly allowed
# 4. AUTH_ALLOWED_EMAIL_DOMAINS allows when the email/domain was not blocked
# 5. If any allow list is configured and there is no allow match, login is denied
# 6. If nothing is configured, login is not blocked by environment rules
AUTH_ALLOWED_EMAILS=
AUTH_BLOCKED_EMAILS=
AUTH_ALLOWED_EMAIL_DOMAINS=
AUTH_BLOCKED_EMAIL_DOMAINS=

# ----------------------------------------------------------------------------
# APPLICATION
# ----------------------------------------------------------------------------
APP_ENV=development
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo
CORS_ORIGINS=http://localhost:9000

# ----------------------------------------------------------------------------
# OPTIONAL: Redis (for rate limiting in production)
# ----------------------------------------------------------------------------
# REDIS_ENABLED=false
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
