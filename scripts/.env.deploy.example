# ============================================================================
# QueueMaster - Deploy Environment Configuration
# ============================================================================
# Copy this file to ../.env and configure before running ./scripts/deploy.sh
# The setup wizard can also generate ../.env for you.
# NEVER commit .env to version control!

# ----------------------------------------------------------------------------
# SERVER / DOMAIN
# ----------------------------------------------------------------------------
# Your server domain or IP (used for CORS and frontend API URL)
# Examples: queuemaster.yourdomain.com, 192.168.1.100
SERVER_DOMAIN=your.domain.com

# Port to expose HTTP (external, what NPM/reverse proxy points to)
# Use 80 only if no other reverse proxy is running
HTTP_PORT=3000

# ----------------------------------------------------------------------------
# DATABASE
# ----------------------------------------------------------------------------
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
DB_USER=queuemaster
DB_PASS=CHANGE_ME_APP_PASSWORD
DB_NAME=queue_master
# External port for direct DB access (default: 3307 to avoid conflict)
DB_PORT_EXPOSE=3307

# ----------------------------------------------------------------------------
# GOOGLE OAUTH (Required)
# ----------------------------------------------------------------------------
# From: Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ----------------------------------------------------------------------------
# ADMIN
# ----------------------------------------------------------------------------
# First user to login with this email gets admin role
SUPER_ADMIN_EMAIL=your.email@gmail.com

# Optional environment access control (recommended for closed staging/test)
# Comma-separated values. Leave empty to disable.
# Precedence:
# 1. AUTH_BLOCKED_EMAILS always denies
# 2. AUTH_ALLOWED_EMAILS explicitly allows and overrides blocked domains
# 3. AUTH_BLOCKED_EMAIL_DOMAINS denies when the email was not explicitly allowed
# 4. AUTH_ALLOWED_EMAIL_DOMAINS allows when the email/domain was not blocked
# 5. If any allow list exists and no allow rule matches, login is denied
# 6. If nothing is configured, environment rules do not block login
AUTH_ALLOWED_EMAILS=
AUTH_BLOCKED_EMAILS=
AUTH_ALLOWED_EMAIL_DOMAINS=
AUTH_BLOCKED_EMAIL_DOMAINS=

# ----------------------------------------------------------------------------
# APPLICATION
# ----------------------------------------------------------------------------
APP_TIMEZONE=America/Sao_Paulo
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000

# CORS: allowed origins (auto-generated from SERVER_DOMAIN)
# Format: https://domain (comma-separated for multiple)
CORS_ORIGINS=https://your.domain.com

# Frontend API URL (auto-generated from SERVER_DOMAIN)
VITE_API_URL=https://your.domain.com/api/v1
